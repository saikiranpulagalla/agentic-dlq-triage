# AgenticDLQ Triage Environment Configuration
# Copy this file to .env and fill in your API keys

# Groq API Configuration (recommended for fast inference)
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.1-8b-instant

# Alternative: OpenAI API Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# MODEL_NAME=gpt-4o-mini

# Local server configuration (usually no need to change)
API_BASE_URL=http://localhost:8000

# Available Groq models:
# - llama-3.1-8b-instant (default, fast)
# - llama-3.1-70b-versatile (slower, more capable)
# - mixtral-8x7b-32768 (good balance)

# Available OpenAI models:
# - gpt-4o-mini (recommended, cost-effective)
# - gpt-4o (most capable, expensive)
# - gpt-3.5-turbo (legacy, cheaper)